classDiagram
    %% PawPal+ system design (draft)
    %% Refine this so it matches your final implementation.

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class Owner {
        +str name
        +int minutes_available
        +List~str~ preferences
        +List~Pet~ pets
        +add_pet(pet Pet) void
        +set_availability(minutes int) void
        +add_preference(pref str) void
        +all_tasks() List~Task~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +List~Task~ tasks
        +add_task(task Task) void
        +remove_task(task Task) void
        +pending_tasks() List~Task~
    }

    class Task {
        +str title
        +int duration_minutes
        +Priority priority
        +bool recurring
        +bool done
        +str notes
        +fits_in(minutes int) bool
        +mark_complete() void
        +mark_incomplete() void
    }

    class ScheduledTask {
        +Task task
        +time start
        +time end
        +overlaps(other ScheduledTask) bool
    }

    class Scheduler {
        +Owner owner
        +time day_start
        +sort_by_priority() List~Task~
        +filter_by_time(tasks List~Task~) List~Task~
        +resolve_conflicts(scheduled List~ScheduledTask~) List~ScheduledTask~
        +build_plan() List~ScheduledTask~
        +explain_plan() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Task --> Priority : rated by
    ScheduledTask --> Task : wraps
    Scheduler --> Owner : plans for
    Scheduler ..> ScheduledTask : produces
