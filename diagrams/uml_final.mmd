classDiagram
    %% PawPal+ system design (draft)
    %% Refine this so it matches your final implementation.

    class Priority {
        <<enumeration>>
        LOW
        MEDIUM
        HIGH
    }

    class Owner {
        +str name
        +int minutes_available
        +List~str~ preferences
        +List~Pet~ pets
        +add_pet(pet Pet) void
        +set_availability(minutes int) void
        +add_preference(pref str) void
        +all_tasks() List~Task~
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +List~Task~ tasks
        +add_task(task Task) void
        +remove_task(task Task) void
        +pending_tasks() List~Task~
        +mark_task_complete(task Task) Task
    }

    class Task {
        +str title
        +int duration_minutes
        +Priority priority
        +str time
        +str frequency
        +date due_date
        +bool done
        +str notes
        +fits_in(minutes int) bool
        +mark_complete() void
        +mark_incomplete() void
        +is_recurring() bool
        +next_occurrence(from_date date) Task
    }

    class ScheduledTask {
        +Task task
        +time start
        +time end
        +overlaps(other ScheduledTask) bool
    }

    class Scheduler {
        +Owner owner
        +time day_start
        +sort_by_priority() List~Task~
        +sort_by_time() List~Task~
        +filter_tasks(done bool, pet_name str) List~Task~
        +detect_conflicts() List~str~
        +filter_by_time(tasks List~Task~) List~Task~
        +resolve_conflicts(scheduled List~ScheduledTask~) List~ScheduledTask~
        +build_plan() List~ScheduledTask~
        +explain_plan() str
    }

    Owner "1" *-- "*" Pet : owns
    Pet "1" *-- "*" Task : has
    Task --> Priority : rated by
    Task ..> Task : spawns next
    Pet ..> Task : auto-repeats
    ScheduledTask "1" --> "1" Task : wraps
    Scheduler --> Owner : plans for
    Scheduler ..> Task : orders & filters
    Scheduler ..> ScheduledTask : produces
